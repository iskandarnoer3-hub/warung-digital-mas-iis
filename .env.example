# ============================================================
# ENV EXAMPLE - Warung Solusi Mas Iis
# Copy this file to .env and fill with your real values
# ============================================================

# --- DATABASE (Supabase PostgreSQL) ---
# Pooler URL (for app queries / Vercel serverless)
DATABASE_URL=postgresql://postgres.REF_ID:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct URL (for migrations)
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.REF_ID.supabase.co:5432/postgres

# --- SUPABASE ---
SUPABASE_URL=https://REF_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- GROQ AI (Chatbot) ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- TELEGRAM BOT (notifications) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- EMAIL (Resend) ---
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_domain@resend.dev

# --- ADMIN PANEL ---
ADMIN_PASSWORD=your_admin_password

# --- NEXTAUTH ---
NEXTAUTH_SECRET=your_nextauth_secret_string
NEXTAUTH_URL=https://your-domain.vercel.app

# --- APP CONFIG ---
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=Warung Solusi - Mas Iis
NEXT_PUBLIC_WA_NUMBER=62XXXXXXXXXXX
NEXT_PUBLIC_OWNER_NAME=Mas Iis
NEXT_PUBLIC_OWNER_LOCATION=Sindanglaut, Kab. Cirebon
